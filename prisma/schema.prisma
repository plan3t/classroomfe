generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TEACHER
}

enum RoomTopic {
  SUPERMARKET
}

enum Language {
  DE
  EN
  FR
  ES
}

enum RoomStatus {
  WAITING
  ACTIVE
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(TEACHER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  rooms         Room[]
  accounts      Account[]
  sessions      Session[]
}

model Room {
  id               String        @id @default(cuid())
  teacherId        String
  teacher          User          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  topic            RoomTopic     @default(SUPERMARKET)
  language         Language
  languageHelp     Boolean       @default(false)
  joinId           String        @unique @db.Char(8)
  joinUrl          String
  qrCodeDataUrl    String
  status           RoomStatus    @default(WAITING)
  expiresAt        DateTime
  startedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  participants     Participant[]
  answers          StudentAnswer[]

  @@index([teacherId, status])
  @@index([joinId, status])
}

model Participant {
  id          String          @id @default(cuid())
  roomId       String
  room         Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  displayName  String
  socketId     String?
  status       ParticipantStatus @default(WAITING)
  joinedAt     DateTime        @default(now())
  answers      StudentAnswer[]

  @@unique([roomId, displayName])
}

enum ParticipantStatus {
  WAITING
  ACTIVE
  COMPLETED
}

model Item {
  id            String          @id @default(cuid())
  topic         RoomTopic       @default(SUPERMARKET)
  imageUrl      String
  order         Int
  translations  ItemTranslation[]

  @@unique([topic, order])
}

model ItemTranslation {
  id            String    @id @default(cuid())
  itemId        String
  item          Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  language      Language
  label         String
  alternatives  String[]

  @@unique([itemId, language])
}

model StudentAnswer {
  id             String   @id @default(cuid())
  roomId          String
  room            Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  language        Language
  submittedText   String
  normalizedText  String
  isCorrect       Boolean
  createdAt       DateTime @default(now())

  @@unique([participantId, itemId])
  @@index([roomId, participantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
